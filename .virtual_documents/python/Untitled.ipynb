# importing json module to work with json data





def load_json_data(filename):  #function to load the json data from a file
    with open(filename,"r") as f:
        data = json.load(f)
        return data


def get_friends_name(names_list,data):
    friends_list = []
    for user in data["users"]:
        if user["id"] in names_list:
            friends_list.append(user["name"])
    return friends_list
    





def display_user_details() : # function to display the user details
    data = load_json_data("data.json")
    print(data)
    for user in data["users"]:
        print(f"User Id : {user["id"]} , Username : {user["name"]} , Friends : { get_friends_name(user["friends"],data)}    ")


display_user_details()
